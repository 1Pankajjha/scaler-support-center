# Frontend Environment Variables
# Copy this to .env.local for local development

# API Base URL for production deployments
# For Railway: Set this to your backend service URL
# Example: VITE_API_URL=https://your-backend-service.up.railway.app
VITE_API_URL=

# OpenAI API Key (if needed for frontend operations)
# VITE_OPENAI_API_KEY=
